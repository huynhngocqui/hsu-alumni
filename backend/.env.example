# App
ENVIRONMENT=development
DEBUG=1
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_URL=http://127.0.0.1:3456
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3456,http://localhost:3456
DJANGO_SECRET_KEY=<required>
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,backend

# Existing database (legacy source for migration)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
LEGACY_DB_ENGINE=django.db.backends.sqlite3
LEGACY_DB_NAME=db.sqlite3
LEGACY_DB_USER=
LEGACY_DB_PASSWORD=
LEGACY_DB_HOST=
LEGACY_DB_PORT=

# MongoDB
MONGODB_ENABLED=0
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=hsu_alumni
MONGODB_AUTH_SOURCE=admin
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_TLS=0
MONGODB_TAGS_COLLECTION=tags
MONGODB_COOP_COLLECTION=coop_listings
MONGODB_JOB_LISTINGS_COLLECTION=job_listings
MONGODB_JOB_APPLICATIONS_COLLECTION=job_applications
MONGODB_USERS_COLLECTION=users

# Auth / Security
SESSION_SECRET=<required>
COOKIE_SECRET=<required>
CSRF_SECRET=<required>
PASSWORD_HASH_SECRET=<required>

# JWT (optional)
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Email (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=

# Storage (optional)
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Background jobs
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0